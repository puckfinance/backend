// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  email     String     @unique
  password  String
  TradeLog  TradeLog[]

  TradeAccount    TradeAccount[]
  Strategy        Strategy[]
  MarketAnalysis  MarketAnalysis[]
}

model TradeLog {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  date            DateTime
  pair            String
  risk            Float
  entryPrice      Float
  stoplossPrice   Float
  takeprofitPrice Float
  note            String
  side            TradeSide
  screenshotUrl   String?
  user            User      @relation(fields: [userId], references: [id])
  userId          String
}

model TradeAccount {
  id         String    @id @default(uuid())
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  apiKey     String
  secretKey  String
  secret     String    @default("")
  provider   Provider
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  Strategy   Strategy? @relation(fields: [strategyId], references: [id])
  strategyId String?

  @@unique([apiKey, secretKey])
}

model Strategy {
  id                   String         @id @default(uuid())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  name                 String
  description          String
  owner                User           @relation(fields: [ownerId], references: [id])
  ownerId              String
  fileUrl              String?
  averageMonthlyReturn Float?
  tradeAccount         TradeAccount[]
}

enum TradeSide {
  LONG
  SHORT
}

enum Provider {
  BINANCE
  BYBIT
  MEXC
}

model MarketAnalysis {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core identifiers
  symbol    String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  // Market Overview
  price                    Float
  priceChange24h           Float
  priceChangePercentage24h Float
  marketCap                Float
  volume24h                Float
  circulatingSupply        Float
  ath                      Float
  athDate                  String
  distanceFromAth          Float

  // DXY / Macro
  dxyPrice     Float?
  eurusd       Float?
  gbpusd       Float?
  usdjpy       Float?
  macroEvents  Json?    // Array of upcoming macro events

  // Technical Levels
  keySupport     Float
  keyResistance  Float
  dailyHigh      Float
  dailyLow       Float

  // Sentiment
  fearGreedIndex         Int
  fearGreedClassification String
  fundingRate            Float
  longShortRatio         Float
  marketBias             String

  // Whale Activity
  whaleData Json?   // Full whale activity snapshot

  // Technical Indicators (daily primary)
  rsi              Float
  rsiCondition     String
  macdHistogram    Float
  macdTrend        String
  emaTrend         String
  marketStructure  String
  bollingerSqueeze Boolean
  bollingerPercentB Float
  atr              Float
  vwapRelation     String

  // Full indicator suite per timeframe
  indicators Json?   // Complete IndicatorSuite for 1d, 4h, 1h

  // DeFi Context
  defiTvl       Float?
  defiProtocols Json?   // Top 5 protocols
  defiHealth    String?

  // AI Analysis (the markdown text from streaming)
  analysisText String?   // Full AI-generated markdown analysis

  // AI Insights
  aiInsights Json?    // { keyObservations, riskFactors, opportunities, tradingConsiderations }

  // Summary & Verdict
  shortTermOutlook    String?
  mediumTermOutlook   String?
  keyLevelToWatch     String?
  recommendedStrategy String?
  confidenceScore     Float?
  overallVerdict      String?   // STRONG_BUY | BUY | NEUTRAL | SELL | STRONG_SELL

  // Trade Alert
  tradeAlertActive     Boolean?
  tradeAlertDirection  String?
  tradeAlertEntryPrice Float?
  tradeAlertStopLoss   Float?
  tradeAlertTakeProfit Float?
  tradeAlertRiskReward Float?
  tradeAlertSetup      String?
  tradeAlertReasoning  String?

  @@index([symbol])
  @@index([createdAt])
  @@index([userId])
  @@index([symbol, createdAt])
}
